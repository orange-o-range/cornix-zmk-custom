/*
 * 2026-05-23: Replaced upstream's complex 8-layer keymap (custom homerow
 * mods, combos, conditional_layers, Win / Adjust / Navi / NumPad / Debug
 * layers) with a slim 4-layer default matching the day-to-day ZMK Studio
 * working state. Intent: a fresh flash or settings reset (cornix_reset.uf2)
 * should land close to actual usage, not the upstream author's untouched
 * setup.
 *
 * 2026-06-02: Re-synced the per-layer `bindings` to the live ZMK Studio
 * working state, captured via the keymap export from zmk-studio-tweaks
 * (Cornix-2026-06-02T14-47-56.keymap). Notable changes vs the 2026-05-23
 * default: Bluetooth keys consolidated onto the Symbols layer only (removed
 * from Number/Functions), the Base-layer right-pinky `!`/`?` dropped to
 * &none, and several JIS symbol slots on Number/Symbols remapped. After a
 * reset, a fresh flash now lands on this exact working state.
 *
 * ZMK Studio interaction:
 *   - Studio overrides per-layer `bindings` via NVS at runtime; the
 *     `bindings` here are the post-reset / pre-Studio-edit defaults.
 *   - Studio does NOT cover `sensor-bindings` (encoders), combos,
 *     behaviors, conditional_layers or macros — those keep being
 *     controlled by this file at runtime regardless of Studio state.
 *     The Studio export omits sensor-bindings, so they are preserved
 *     here by hand.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        Base {
            display-name = "Base";
            bindings = <
&kp PRSC   &kp Q     &kp W     &kp E      &kp R        &kp T                                                &kp Y            &kp U     &kp I      &kp O     &kp P     &kp MINUS
&kp CAPS   &kp A     &kp S     &kp D      &kp F        &kp G                                                &kp H            &kp J     &kp K      &kp L     &kp RET   &none
&kp LSHFT  &kp Z     &kp X     &kp C      &kp V        &kp B            &none            &none              &kp N            &kp M     &kp COMMA  &kp DOT   &kp UP    &none
&kp LCTL   &kp LGUI  &kp LALT  &lt 1 TAB  &lt 2 SPACE  &mt LSHFT LANG2                                      &mt RSHFT LANG1  &kp BSPC  &mo 2      &kp LEFT  &kp DOWN  &kp RIGHT
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        Symbols {
            display-name = "Symbols";
            bindings = <
&bt BT_CLR    &kp LS(N2)  &kp LS(N7)  &none       &none   &none                          &kp LS(COMMA)  &kp LS(DOT)  &kp RBKT      &kp NUHS      &kp LS(N5)  &none
&bt BT_SEL 0  &kp LBKT    &kp LS(N3)  &kp LS(N4)  &none   &none                          &none          &none        &kp LS(RBKT)  &kp LS(NUHS)  &none       &none
&bt BT_SEL 1  &none       &none       &none       &none   &none      &trans   &trans    &none          &none        &kp LS(N1)    &kp LS(FSLH)  &none       &none
&bt BT_SEL 2  &none       &none       &none       &trans  &trans                         &trans         &trans       &none         &none         &none       &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        Number {
            display-name = "Number";
            bindings = <
&none  &kp LS(SEMI)  &kp N7  &kp N8  &kp N9  &kp LS(SQT)                  &none      &none     &kp UP    &none      &none         &none
&none  &kp MINUS     &kp N4  &kp N5  &kp N6  &kp FSLH                     &none      &kp LEFT  &kp DOWN  &kp RIGHT  &kp LS(MINUS)  &none
&none  &kp N0        &kp N1  &kp N2  &kp N3  &kp DOT      &none   &none   &none      &none     &none     &none      &none         &none
&none  &none         &none   &none   &none   &none                        &kp RSHFT  &mo 3     &none     &none      &none         &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        Functions {
            display-name = "Functions";
            bindings = <
&none  &none  &kp F7  &kp F8  &kp F9  &kp F12                  &none  &none  &none  &none  &none  &none
&none  &none  &kp F4  &kp F5  &kp F6  &kp F11                  &none  &none  &none  &none  &none  &none
&none  &none  &kp F1  &kp F2  &kp F3  &kp F10  &none  &none    &none  &none  &none  &none  &none  &none
&none  &none  &none   &none   &none   &none                    &none  &none  &none  &none  &none  &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };
    };
};
